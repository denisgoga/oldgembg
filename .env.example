# Copy to `.env` and fill with your NEW Supabase project (Project Settings → API).
# Never commit `.env` or put the service_role key in the frontend.

# --- Required for the React app (Vite exposes only VITE_* to the browser) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable (recommended) or legacy anon JWT — same key shown as "anon public" in older dashboards
VITE_SUPABASE_KEY=your_publishable_or_anon_key_here

# Optional: override default bucket name (must match Storage bucket in Supabase)
# VITE_VIDEO_THUMB_BUCKET=video-thumbnails

# Optional: set to "true" to skip server catalog proxy during local debugging
# VITE_DISABLE_CATALOG_API=false
# VITE_DISABLE_VIDEO_REALTIME=false

# --- Express server / Netlify (catalog API reads these; fallback is VITE_* above) ---
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key_here
# Or: SUPABASE_ANON_KEY=

# --- Admin login (generate a long random string for secret) ---
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=

# --- Vercel ---
# Copy every variable above into the Vercel project (Settings → Environment Variables).
# Set the same keys for Production, Preview, and Development so local `vercel dev` matches production.
# Sensitive keys cannot use the “Sensitive” flag for Development — add them as plain encrypted values there, or omit admin secrets from Development only.
